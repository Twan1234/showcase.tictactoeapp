{
  "compilerOptions": {
    "target": "es6",
    "module": "commonjs",
    "lib": [ "es6", "dom" ],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "allowJs": true,
    "types": [ "cypress", "@cypress/react" ],
    "jsx": "react"
  },
  "include": [ "cypress/**/*.ts", "**/*.tsx", "cypress", "src" ]
}